namespace: 'Alto'
import: 'Go'

Transcript subclass: View
  instanceVars: lines <Array> maxLines <Integer> scrollOffset <Integer> display <Display> parentWindow <Window>
  classVars: Current

  classMethod: new ^<Transcript> [
      | instance <Transcript> |
      instance := super new.
      instance initialize.
      ^instance
  ]

  classMethod: current ^<Transcript> [
      Current isNil ifTrue: [Current := self new].
      ^Current
  ]

  classMethod: show: aString <String> [
      self current appendLine: aString
  ]

  classMethod: open: aDisplay <Display> ^<Transcript> [
      | frame <Rectangle> transcript <Transcript> window <Window> |
      frame := Rectangle x: 1 y: 22 width: 60 height: 10.
      transcript := self current.
      transcript display: aDisplay.
      window := Window title: 'Transcript' content: transcript controller: transcript frame: frame.
      transcript parentWindow: window.
      aDisplay addWindow: window.
      ^transcript
  ]

  method: initialize [
      super initialize.
      lines := ArrayList new.
      maxLines := 1000.
      scrollOffset := 0.
      display := nil.
      parentWindow := nil
  ]

  method: appendLine: aString <String> [
      lines add: aString.
      [lines size > maxLines] whileTrue: [lines removeAt: 0].
      scrollOffset := (lines size - 1) max: 0.
      self invalidate
  ]

  method: handleEvent: evt <Event> [
    | keyCode <Integer> |
    evt isKey ifFalse: [^self].
    keyCode := evt key.
    keyCode = EventConstants keyUp ifTrue: [  "Up"
      scrollOffset := (scrollOffset - 1) max: 0.
      self invalidate
    ].
    keyCode = EventConstants keyDown ifTrue: [  "Down"
      scrollOffset := (scrollOffset + 1) min: ((lines size - 1) max: 0).
      self invalidate
    ].
    keyCode = EventConstants keyEscape ifTrue: [  "Escape"
      display notNil ifTrue: [display removeWindow: parentWindow]
    ]
  ]

  method: displayOn: aCellBuffer <CellBuffer> [
    | visibleHeight <Integer> i <Integer> lineIndex <Integer> lineStr <String> startOffset <Integer> |
    visibleHeight := aCellBuffer height.
    startOffset := (lines size - visibleHeight) max: 0.
    scrollOffset < startOffset ifTrue: [
      startOffset := scrollOffset
    ].
    i := 0.
    [i < visibleHeight] whileTrue: [
      lineIndex := startOffset + i.
      lineIndex < lines size ifTrue: [
        lineStr := lines at: lineIndex.
        aCellBuffer putString: lineStr x: 0 y: i style: Theme normalStyle
      ].
      i := i + 1
    ]
  ]

  method: parentWindow: aWindow <Window> [
      parentWindow := aWindow
  ]

  method: display: aDisplay <Display> [
      display := aDisplay
  ]

  method: lines ^<Array> [
      ^lines
  ]

  method: maxLines ^<Integer> [
      ^maxLines
  ]

  method: scrollOffset ^<Integer> [
      ^scrollOffset
  ]

namespace: 'Alto'
import: 'Go'

"Theme — standard named styles for the Alto UI.
 Centralizes all Go::Terminal newStyle calls so widgets
 share a single source of truth for visual appearance."

Theme subclass: Object
  classVars: CachedNormal CachedReverse CachedDim CachedBold CachedDivider

  classMethod: normalStyle [
    CachedNormal isNil ifTrue: [CachedNormal := Go::Terminal newStyle].
    ^CachedNormal
  ]

  classMethod: reverseStyle [
    CachedReverse isNil ifTrue: [CachedReverse := (Go::Terminal newStyle) reverse: true].
    ^CachedReverse
  ]

  classMethod: selectedStyle [
    ^self reverseStyle
  ]

  classMethod: dimStyle [
    CachedDim isNil ifTrue: [CachedDim := (Go::Terminal newStyle) dim: true].
    ^CachedDim
  ]

  classMethod: boldStyle [
    CachedBold isNil ifTrue: [CachedBold := (Go::Terminal newStyle) bold: true].
    ^CachedBold
  ]

  classMethod: borderStyle [
    ^self normalStyle
  ]

  classMethod: dividerStyle [
    CachedDivider isNil ifTrue: [CachedDivider := (Go::Terminal newStyle) dim: true].
    ^CachedDivider
  ]

  classMethod: resetCache [
    "Call if terminal restarts or theme changes."
    CachedNormal := nil.
    CachedReverse := nil.
    CachedDim := nil.
    CachedBold := nil.
    CachedDivider := nil
  ]

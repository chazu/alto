namespace: 'Alto'
import: 'Go'

"Phase 5 Spec Tests — Comprehensive spec-driven tests for Workspace, Transcript, and Main.
 Each test group is isolated so that a crash in one group does not block others.
 Tests behavior from the spec, not implementation details.
 Uses integer char codes, not dollar-sign literals."

"Simple test runner."
T5S subclass: Object
  instanceVars: passed failed failures

  classMethod: new [
    | r |
    r := super new.
    r init.
    ^ r
  ]

  method: init [
    passed := 0.
    failed := 0.
    failures := Array new: 0
  ]

  method: assert: condition message: msg [
    condition ifTrue: [
      passed := passed + 1
    ] ifFalse: [
      failed := failed + 1.
      failures := failures copyWith: msg.
      ('FAIL: ', msg) println
    ]
  ]

  method: assertEqual: actual to: expected message: msg [
    (actual = expected) ifTrue: [
      passed := passed + 1
    ] ifFalse: [
      failed := failed + 1.
      failures := failures copyWith: msg.
      ('FAIL: ', msg, ' (got: ', actual printString, ' expected: ', expected printString, ')') println
    ]
  ]

  method: report [
    '=== Phase 5 Spec Test Results ===' println.
    ('Passed: ', passed printString) println.
    ('Failed: ', failed printString) println.
    (failed > 0) ifTrue: [
      'Failures:' println.
      failures do: [:f | ('  - ', f) println]
    ].
    (failed = 0)
      ifTrue: [ 'ALL TESTS PASSED' println ]
      ifFalse: [ 'SOME TESTS FAILED' println ]
  ]

  method: failed [
    ^ failed
  ]

"Helper to make events with integer char codes."
EvtH subclass: Object

  classMethod: runeEvent: charCode [
    | evt |
    evt := Dictionary new.
    evt at: #key put: #rune.
    evt at: #rune put: charCode.
    ^evt
  ]

  classMethod: keyEvent: keySymbol [
    | evt |
    evt := Dictionary new.
    evt at: #key put: keySymbol.
    ^evt
  ]


"=== WORKSPACE CONSTRUCTION TESTS ==="
WSConstructionTests subclass: Object

  classMethod: run: t [
    | ws ws2 |
    '--- Workspace Construction Tests ---' println.

    "WS-C1: Workspace new creates instance with correct defaults"
    ws := Workspace new.
    t assertEqual: (ws textLines size) to: 0 message: 'WS-C1a: textLines starts empty'.
    t assertEqual: (ws cursorX) to: 0 message: 'WS-C1b: cursorX starts at 0'.
    t assertEqual: (ws cursorY) to: 0 message: 'WS-C1c: cursorY starts at 0'.
    t assertEqual: (ws scrollOffset) to: 0 message: 'WS-C1d: scrollOffset starts at 0'.

    "WS-C2: Workspace is a subclass of View — test by calling View protocol methods"
    ws2 := Workspace new.
    ws2 invalidate.
    t assertEqual: (ws2 needsRedraw) to: true message: 'WS-C2a: has needsRedraw (View method)'.
    t assert: (ws2 needsRedraw notNil) message: 'WS-C2b: needsRedraw returns non-nil'.

    "WS-C3: Workspace responds to parentWindow:/display: setters"
    ws := Workspace new.
    ws parentWindow: nil.
    ws display: nil.
    t assert: true message: 'WS-C3: parentWindow:/display: setters work without error'.

    "WS-C4: Workspace responds to handleEvent: (controller protocol)"
    ws := Workspace new.
    t assert: true message: 'WS-C4: Workspace has handleEvent: method'
  ]


"=== WORKSPACE TEXT EDITING TESTS ==="
WSEditingTests subclass: Object

  classMethod: run: t [
    | ws ws2 ws3 ws4 ws5 ws6 ws7 ws8 ws9 ws10 |
    '--- Workspace Text Editing Tests ---' println.

    "WS-E1: Inserting a printable char creates a line and inserts the char"
    ws := Workspace new.
    ws handleEvent: (EvtH runeEvent: 65).
    t assertEqual: (ws textLines size) to: 1 message: 'WS-E1a: textLines has 1 line after char insert'.
    t assertEqual: (ws textLines at: 1) to: 'A' message: 'WS-E1b: first line is A'.
    t assertEqual: (ws cursorX) to: 1 message: 'WS-E1c: cursorX = 1 after insert'.

    "WS-E2: Multiple chars typed in sequence"
    ws2 := Workspace new.
    ws2 handleEvent: (EvtH runeEvent: 72).
    ws2 handleEvent: (EvtH runeEvent: 105).
    t assertEqual: (ws2 textLines at: 1) to: 'Hi' message: 'WS-E2a: line contains Hi'.
    t assertEqual: (ws2 cursorX) to: 2 message: 'WS-E2b: cursorX = 2 after two chars'.

    "WS-E3: Enter splits line and moves cursor to next line"
    ws3 := Workspace new.
    ws3 handleEvent: (EvtH runeEvent: 97).
    ws3 handleEvent: (EvtH runeEvent: 98).
    ws3 handleEvent: (EvtH keyEvent: #enter).
    ws3 handleEvent: (EvtH runeEvent: 99).
    ws3 handleEvent: (EvtH runeEvent: 100).
    t assertEqual: (ws3 textLines size) to: 2 message: 'WS-E3a: 2 lines after enter'.
    t assertEqual: (ws3 textLines at: 1) to: 'ab' message: 'WS-E3b: first line is ab'.
    t assertEqual: (ws3 textLines at: 2) to: 'cd' message: 'WS-E3c: second line is cd'.
    t assertEqual: (ws3 cursorY) to: 1 message: 'WS-E3d: cursorY = 1'.
    t assertEqual: (ws3 cursorX) to: 2 message: 'WS-E3e: cursorX = 2'.

    "WS-E4: Insert in middle of line"
    ws4 := Workspace new.
    ws4 handleEvent: (EvtH runeEvent: 97).
    ws4 handleEvent: (EvtH runeEvent: 99).
    ws4 handleEvent: (EvtH keyEvent: #left).
    ws4 handleEvent: (EvtH runeEvent: 98).
    t assertEqual: (ws4 textLines at: 1) to: 'abc' message: 'WS-E4a: insert in middle gives abc'.
    t assertEqual: (ws4 cursorX) to: 2 message: 'WS-E4b: cursorX = 2 after mid-insert'.

    "WS-E5: Enter splits line in middle"
    ws5 := Workspace new.
    ws5 handleEvent: (EvtH runeEvent: 97).
    ws5 handleEvent: (EvtH runeEvent: 98).
    ws5 handleEvent: (EvtH runeEvent: 99).
    ws5 handleEvent: (EvtH runeEvent: 100).
    ws5 handleEvent: (EvtH keyEvent: #left).
    ws5 handleEvent: (EvtH keyEvent: #left).
    ws5 handleEvent: (EvtH keyEvent: #enter).
    t assertEqual: (ws5 textLines size) to: 2 message: 'WS-E5a: enter mid-line creates 2 lines'.
    t assertEqual: (ws5 textLines at: 1) to: 'ab' message: 'WS-E5b: first line is ab'.
    t assertEqual: (ws5 textLines at: 2) to: 'cd' message: 'WS-E5c: second line is cd'.
    t assertEqual: (ws5 cursorY) to: 1 message: 'WS-E5d: cursorY = 1'.
    t assertEqual: (ws5 cursorX) to: 0 message: 'WS-E5e: cursorX = 0'.

    "WS-E6: Backspace in middle of line removes char"
    ws6 := Workspace new.
    ws6 handleEvent: (EvtH runeEvent: 97).
    ws6 handleEvent: (EvtH runeEvent: 98).
    ws6 handleEvent: (EvtH runeEvent: 99).
    ws6 handleEvent: (EvtH keyEvent: #backspace).
    t assertEqual: (ws6 textLines at: 1) to: 'ab' message: 'WS-E6a: backspace removes last char'.
    t assertEqual: (ws6 cursorX) to: 2 message: 'WS-E6b: cursorX = 2 after backspace'.

    "WS-E7: Backspace at start of non-first line merges with previous"
    ws7 := Workspace new.
    ws7 handleEvent: (EvtH runeEvent: 97).
    ws7 handleEvent: (EvtH runeEvent: 98).
    ws7 handleEvent: (EvtH keyEvent: #enter).
    ws7 handleEvent: (EvtH runeEvent: 99).
    ws7 handleEvent: (EvtH runeEvent: 100).
    ws7 handleEvent: (EvtH keyEvent: #left).
    ws7 handleEvent: (EvtH keyEvent: #left).
    ws7 handleEvent: (EvtH keyEvent: #backspace).
    t assertEqual: (ws7 textLines size) to: 1 message: 'WS-E7a: lines merged to 1'.
    t assertEqual: (ws7 textLines at: 1) to: 'abcd' message: 'WS-E7b: merged line is abcd'.
    t assertEqual: (ws7 cursorY) to: 0 message: 'WS-E7c: cursorY = 0'.
    t assertEqual: (ws7 cursorX) to: 2 message: 'WS-E7d: cursorX = 2 (end of prev line)'.

    "WS-E8: Backspace at position 0 line 0 is a no-op"
    ws8 := Workspace new.
    ws8 handleEvent: (EvtH runeEvent: 120).
    ws8 handleEvent: (EvtH keyEvent: #left).
    ws8 handleEvent: (EvtH keyEvent: #backspace).
    t assertEqual: (ws8 textLines size) to: 1 message: 'WS-E8a: backspace at 0,0 no change'.
    t assertEqual: (ws8 textLines at: 1) to: 'x' message: 'WS-E8b: line content unchanged'.
    t assertEqual: (ws8 cursorX) to: 0 message: 'WS-E8c: cursorX stays 0'.

    "WS-E9: Enter on empty workspace creates lines"
    ws9 := Workspace new.
    ws9 handleEvent: (EvtH keyEvent: #enter).
    t assert: (ws9 textLines size > 0) message: 'WS-E9a: enter on empty creates lines'.
    t assertEqual: (ws9 cursorY) to: 1 message: 'WS-E9b: cursorY = 1 after enter on empty'.

    "WS-E10: Backspace on empty workspace is a no-op"
    ws10 := Workspace new.
    ws10 handleEvent: (EvtH keyEvent: #backspace).
    t assertEqual: (ws10 textLines size) to: 0 message: 'WS-E10: backspace on empty is no-op'.

    "WS-E11: Char insert invalidates view"
    ws := Workspace new.
    ws handleEvent: (EvtH runeEvent: 97).
    t assertEqual: (ws needsRedraw) to: true message: 'WS-E11: char insert invalidates'
  ]


"=== WORKSPACE NAVIGATION TESTS ==="
WSNavigationTests subclass: Object

  classMethod: run: t [
    | ws ws2 ws3 |
    '--- Workspace Navigation Tests ---' println.

    "WS-N1: Arrow up/down move cursorY within bounds"
    ws := Workspace new.
    ws handleEvent: (EvtH runeEvent: 97).
    ws handleEvent: (EvtH keyEvent: #enter).
    ws handleEvent: (EvtH runeEvent: 98).
    ws handleEvent: (EvtH keyEvent: #enter).
    ws handleEvent: (EvtH runeEvent: 99).
    "3 lines: a, b, c. cursorY = 2"
    ws handleEvent: (EvtH keyEvent: #up).
    t assertEqual: (ws cursorY) to: 1 message: 'WS-N1a: up from 2 gives 1'.
    ws handleEvent: (EvtH keyEvent: #up).
    t assertEqual: (ws cursorY) to: 0 message: 'WS-N1b: up from 1 gives 0'.
    ws handleEvent: (EvtH keyEvent: #up).
    t assertEqual: (ws cursorY) to: 0 message: 'WS-N1c: up at 0 stays 0'.
    ws handleEvent: (EvtH keyEvent: #down).
    ws handleEvent: (EvtH keyEvent: #down).
    ws handleEvent: (EvtH keyEvent: #down).
    t assertEqual: (ws cursorY) to: 2 message: 'WS-N1d: down past last stays at last'.

    "WS-N2: Arrow left/right move cursorX within bounds"
    ws2 := Workspace new.
    ws2 handleEvent: (EvtH runeEvent: 97).
    ws2 handleEvent: (EvtH runeEvent: 98).
    "cursorX = 2"
    ws2 handleEvent: (EvtH keyEvent: #left).
    t assertEqual: (ws2 cursorX) to: 1 message: 'WS-N2a: left from 2 gives 1'.
    ws2 handleEvent: (EvtH keyEvent: #left).
    t assertEqual: (ws2 cursorX) to: 0 message: 'WS-N2b: left from 1 gives 0'.
    ws2 handleEvent: (EvtH keyEvent: #left).
    t assertEqual: (ws2 cursorX) to: 0 message: 'WS-N2c: left at 0 stays 0'.
    ws2 handleEvent: (EvtH keyEvent: #right).
    t assertEqual: (ws2 cursorX) to: 1 message: 'WS-N2d: right from 0 gives 1'.
    ws2 handleEvent: (EvtH keyEvent: #right).
    t assertEqual: (ws2 cursorX) to: 2 message: 'WS-N2e: right from 1 gives 2'.
    ws2 handleEvent: (EvtH keyEvent: #right).
    t assertEqual: (ws2 cursorX) to: 2 message: 'WS-N2f: right past end stays at end'.

    "WS-N3: Up arrow clamps cursorX to shorter line"
    ws3 := Workspace new.
    ws3 handleEvent: (EvtH runeEvent: 97).
    ws3 handleEvent: (EvtH keyEvent: #enter).
    ws3 handleEvent: (EvtH runeEvent: 98).
    ws3 handleEvent: (EvtH runeEvent: 99).
    ws3 handleEvent: (EvtH runeEvent: 100).
    "Line 0 = 'a' (len 1), line 1 = 'bcd' (len 3), cursorX=3"
    ws3 handleEvent: (EvtH keyEvent: #up).
    t assertEqual: (ws3 cursorX) to: 1 message: 'WS-N3: up clamps cursorX to shorter line length'
  ]


"=== WORKSPACE ESCAPE TEST ==="
WSEscapeTests subclass: Object

  classMethod: run: t [
    | ws mockDisplay removed evtEsc |
    '--- Workspace Escape Tests ---' println.

    "WS-ESC1: Escape with nil display does not crash"
    ws := Workspace new.
    ws display: nil.
    evtEsc := EvtH keyEvent: #escape.
    ws handleEvent: evtEsc.
    t assert: true message: 'WS-ESC1: escape with nil display does not crash'
  ]


"=== TRANSCRIPT CONSTRUCTION TESTS ==="
TRConstructionTests subclass: Object

  classMethod: run: t [
    | tr |
    '--- Transcript Construction Tests ---' println.

    "TR-C1: Transcript new creates instance with correct defaults"
    tr := Transcript new.
    t assertEqual: (tr lines size) to: 0 message: 'TR-C1a: lines starts empty'.
    t assertEqual: (tr maxLines) to: 1000 message: 'TR-C1b: maxLines = 1000'.
    t assertEqual: (tr scrollOffset) to: 0 message: 'TR-C1c: scrollOffset starts at 0'.

    "TR-C2: Transcript is a subclass of View"
    tr := Transcript new.
    tr invalidate.
    t assertEqual: (tr needsRedraw) to: true message: 'TR-C2a: has needsRedraw (View method)'.
    t assert: (tr needsRedraw notNil) message: 'TR-C2b: needsRedraw returns non-nil'
  ]


"=== TRANSCRIPT SINGLETON TESTS ==="
TRSingletonTests subclass: Object

  classMethod: run: t [
    | tr1 tr2 |
    '--- Transcript Singleton Tests ---' println.

    "TR-S1: Transcript current returns singleton"
    tr1 := Transcript current.
    tr2 := Transcript current.
    t assert: (tr1 == tr2) message: 'TR-S1: Transcript current returns same object'
  ]


"=== TRANSCRIPT APPEND TESTS ==="
TRAppendTests subclass: Object

  classMethod: run: t [
    | tr tr2 tr3 i |
    '--- Transcript Append Tests ---' println.

    "TR-A1: appendLine: adds to lines array"
    tr := Transcript new.
    tr appendLine: 'hello'.
    t assertEqual: (tr lines size) to: 1 message: 'TR-A1a: lines size = 1'.
    t assertEqual: (tr lines at: 1) to: 'hello' message: 'TR-A1b: line content = hello'.

    "TR-A2: Multiple appends maintain order (newest at bottom)"
    tr appendLine: 'world'.
    t assertEqual: (tr lines size) to: 2 message: 'TR-A2a: lines size = 2'.
    t assertEqual: (tr lines at: 1) to: 'hello' message: 'TR-A2b: first line is hello'.
    t assertEqual: (tr lines at: 2) to: 'world' message: 'TR-A2c: second line is world (newest at bottom)'.

    "TR-A3: appendLine: invalidates (triggers redraw)"
    tr2 := Transcript new.
    tr2 appendLine: 'trigger'.
    t assertEqual: (tr2 needsRedraw) to: true message: 'TR-A3: appendLine: invalidates'.

    "TR-A4: Many appends preserve order"
    tr3 := Transcript new.
    i := 1.
    [i <= 5] whileTrue: [
      tr3 appendLine: i printString.
      i := i + 1
    ].
    t assertEqual: (tr3 lines at: 1) to: '1' message: 'TR-A4a: first append is 1'.
    t assertEqual: (tr3 lines at: 5) to: '5' message: 'TR-A4b: fifth append is 5 (newest at bottom)'.

    "TR-A5: appendLine: auto-scrolls (scrollOffset updates)"
    tr3 := Transcript new.
    tr3 appendLine: 'first'.
    tr3 appendLine: 'second'.
    tr3 appendLine: 'third'.
    t assert: (tr3 scrollOffset >= 0) message: 'TR-A5: scrollOffset updates on append (auto-scroll)'.
    t assertEqual: (tr3 scrollOffset) to: 2 message: 'TR-A5b: scrollOffset = lines size - 1 after append'
  ]


"=== TRANSCRIPT EVENT HANDLING TESTS ==="
TREventTests subclass: Object

  classMethod: run: t [
    | tr tr2 tr3 linesBefore |
    '--- Transcript Event Handling Tests ---' println.

    "TR-EV1: Transcript is read-only — rune event does NOT modify lines"
    tr := Transcript new.
    tr appendLine: 'existing'.
    linesBefore := tr lines size.
    tr handleEvent: (EvtH runeEvent: 88).
    t assertEqual: (tr lines size) to: linesBefore message: 'TR-EV1: printable char does not modify lines'.

    "TR-EV2: Up/down events change scrollOffset"
    tr2 := Transcript new.
    tr2 appendLine: 'line1'.
    tr2 appendLine: 'line2'.
    tr2 appendLine: 'line3'.
    "scrollOffset after 3 appends = 2"
    tr2 handleEvent: (EvtH keyEvent: #up).
    t assert: (tr2 scrollOffset >= 0) message: 'TR-EV2a: scrollOffset >= 0 after up'.
    t assertEqual: (tr2 scrollOffset) to: 1 message: 'TR-EV2b: scrollOffset decrements on up'.
    tr2 handleEvent: (EvtH keyEvent: #down).
    t assertEqual: (tr2 scrollOffset) to: 2 message: 'TR-EV2c: scrollOffset increments on down'.

    "TR-EV3: scrollOffset does not go below 0"
    tr3 := Transcript new.
    tr3 handleEvent: (EvtH keyEvent: #up).
    tr3 handleEvent: (EvtH keyEvent: #up).
    tr3 handleEvent: (EvtH keyEvent: #up).
    t assertEqual: (tr3 scrollOffset) to: 0 message: 'TR-EV3: scrollOffset clamps at 0'.

    "TR-EV4: scrollOffset clamps on down"
    tr3 := Transcript new.
    tr3 appendLine: 'only'.
    tr3 handleEvent: (EvtH keyEvent: #down).
    tr3 handleEvent: (EvtH keyEvent: #down).
    tr3 handleEvent: (EvtH keyEvent: #down).
    t assert: (tr3 scrollOffset <= ((tr3 lines size - 1) max: 0)) message: 'TR-EV4: down scroll clamps at lines size - 1'.

    "TR-EV5: Escape with nil display does not crash"
    tr := Transcript new.
    tr display: nil.
    tr handleEvent: (EvtH keyEvent: #escape).
    t assert: true message: 'TR-EV5: escape with nil display does not crash'.

    "TR-EV6: Up/down on empty transcript"
    tr := Transcript new.
    tr handleEvent: (EvtH keyEvent: #up).
    t assertEqual: (tr scrollOffset) to: 0 message: 'TR-EV6a: up on empty stays 0'.
    tr handleEvent: (EvtH keyEvent: #down).
    t assertEqual: (tr scrollOffset) to: 0 message: 'TR-EV6b: down on empty stays 0'
  ]


"=== WORKSPACE RENDERING TESTS ==="
WSRenderTests subclass: Object

  classMethod: run: t [
    | ws buf cell ws2 buf2 cell2 cell3 ws3 buf3 cell4 |
    '--- Workspace Rendering Tests ---' println.

    "WR1: Empty workspace renders cursor (reverse-video space) at 0,0"
    ws := Workspace new.
    buf := CellBuffer width: 20 height: 10.
    ws displayOn: buf.
    cell := buf cellAt: 0 y: 0.
    t assert: (cell notNil) message: 'WR1a: cell at 0,0 is non-nil'.
    t assertEqual: (cell at: #char) to: 32 message: 'WR1b: empty cursor is space (32)'.
    t assertEqual: (cell at: #attrs) to: #reverse message: 'WR1c: cursor is reverse-video'.

    "WR2: After typing a char, char rendered and cursor at next pos"
    ws2 := Workspace new.
    ws2 handleEvent: (EvtH runeEvent: 65).
    buf2 := CellBuffer width: 20 height: 10.
    ws2 displayOn: buf2.
    cell2 := buf2 cellAt: 0 y: 0.
    t assertEqual: (cell2 at: #char) to: 65 message: 'WR2a: A rendered at (0,0)'.
    cell3 := buf2 cellAt: 1 y: 0.
    t assertEqual: (cell3 at: #char) to: 32 message: 'WR2b: cursor space at (1,0)'.
    t assertEqual: (cell3 at: #attrs) to: #reverse message: 'WR2c: cursor is reverse-video'.

    "WR3: Two lines rendered correctly"
    ws3 := Workspace new.
    ws3 handleEvent: (EvtH runeEvent: 97).
    ws3 handleEvent: (EvtH keyEvent: #enter).
    ws3 handleEvent: (EvtH runeEvent: 98).
    buf3 := CellBuffer width: 20 height: 10.
    ws3 displayOn: buf3.
    cell3 := buf3 cellAt: 0 y: 0.
    t assertEqual: (cell3 at: #char) to: 97 message: 'WR3a: first line a (97) at (0,0)'.
    cell4 := buf3 cellAt: 0 y: 1.
    t assertEqual: (cell4 at: #char) to: 98 message: 'WR3b: second line b (98) at (0,1)'
  ]


"=== TRANSCRIPT RENDERING TESTS ==="
TRRenderTests subclass: Object

  classMethod: run: t [
    | tr buf cell |
    '--- Transcript Rendering Tests ---' println.

    "TRR1: Transcript renders lines into buffer"
    tr := Transcript new.
    tr appendLine: 'Hello'.
    tr appendLine: 'World'.
    buf := CellBuffer width: 20 height: 10.
    tr displayOn: buf.
    cell := buf cellAt: 0 y: 0.
    t assert: (cell notNil) message: 'TRR1: transcript renders into buffer'
  ]


"=== CONVENTION COMPLIANCE TESTS ==="
ConvTests subclass: Object

  classMethod: run: t [
    | ws tr |
    '--- Convention Compliance Tests ---' println.

    "CV1: Workspace textLines starts as empty array"
    ws := Workspace new.
    t assertEqual: (ws textLines size) to: 0 message: 'CV1: textLines starts as empty array'.

    "CV2: Transcript lines starts as empty array"
    tr := Transcript new.
    t assertEqual: (tr lines size) to: 0 message: 'CV2: lines starts as empty array'.

    "CV3: Workspace grows via insertion (copyWith: pattern)"
    ws handleEvent: (EvtH runeEvent: 65).
    t assertEqual: (ws textLines size) to: 1 message: 'CV3: textLines grows via insertion'.

    "CV4: Transcript grows via append (copyWith: pattern)"
    tr appendLine: 'test'.
    t assertEqual: (tr lines size) to: 1 message: 'CV4: lines grows via append'
  ]


"=== MAIN RUNNER ==="
Phase5SpecTests subclass: Object
  classMethod: run [
    | t |
    t := T5S new.

    "Run non-crashing tests first"
    WSConstructionTests run: t.
    '' println.
    TRConstructionTests run: t.
    '' println.
    TRSingletonTests run: t.
    '' println.
    TRAppendTests run: t.
    '' println.
    TREventTests run: t.
    '' println.
    WSEscapeTests run: t.
    '' println.
    ConvTests run: t.

    '' println.
    '=== Non-editing results ===' println.
    t report.
    '' println.

    "Workspace editing tests (may crash if String copyFrom:to: missing)"
    'Attempting Workspace editing tests...' println.
    WSEditingTests run: t.
    '' println.

    "Navigation tests (also need string manipulation for setup)"
    'Attempting Workspace navigation tests...' println.
    WSNavigationTests run: t.
    '' println.

    "Rendering tests"
    'Attempting rendering tests...' println.
    WSRenderTests run: t.
    '' println.
    TRRenderTests run: t.

    '' println.
    '=== Final results ===' println.
    t report.
    ^ t failed
  ]

Phase5SpecTests run

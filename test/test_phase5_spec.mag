namespace: 'Alto'
import: 'Go'

"Phase 5 Spec Tests — Comprehensive spec-driven tests for Workspace, Transcript, and Main.
 Tests behavior from the spec, not implementation details.
 Uses integer char codes, not dollar-sign literals.
 Uses 0-based array indexing (confirmed by runtime experiments)."

"Simple test runner."
T5S subclass: Object
  instanceVars: passed failed failures

  classMethod: new [
    | r |
    r := super new.
    r init.
    ^ r
  ]

  method: init [
    passed := 0.
    failed := 0.
    failures := Array new: 0
  ]

  method: assert: condition message: msg [
    condition ifTrue: [
      passed := passed + 1
    ] ifFalse: [
      failed := failed + 1.
      failures := failures copyWith: msg.
      ('FAIL: ', msg) println
    ]
  ]

  method: assertEqual: actual to: expected message: msg [
    (actual = expected) ifTrue: [
      passed := passed + 1
    ] ifFalse: [
      failed := failed + 1.
      failures := failures copyWith: msg.
      ('FAIL: ', msg, ' (got: ', actual printString, ' expected: ', expected printString, ')') println
    ]
  ]

  method: report [
    '=== Phase 5 Spec Test Results ===' println.
    ('Passed: ', passed printString) println.
    ('Failed: ', failed printString) println.
    (failed > 0) ifTrue: [
      'Failures:' println.
      failures do: [:f | ('  - ', f) println]
    ].
    (failed = 0)
      ifTrue: [ 'ALL TESTS PASSED' println ]
      ifFalse: [ 'SOME TESTS FAILED' println ]
  ]

  method: failed [
    ^ failed
  ]

"Helper to make events."
EvtH subclass: Object

  classMethod: runeEvent: charCode [
    | evt |
    evt := Dictionary new.
    evt at: #key put: #rune.
    evt at: #rune put: charCode.
    ^evt
  ]

  classMethod: keyEvent: keySymbol [
    | evt |
    evt := Dictionary new.
    evt at: #key put: keySymbol.
    ^evt
  ]


"=== WORKSPACE CONSTRUCTION TESTS ==="
WSConstructionTests subclass: Object

  classMethod: run: t [
    | ws ws2 |
    '--- Workspace Construction Tests ---' println.

    "WS-C1: Workspace new creates instance with correct defaults"
    ws := Workspace new.
    t assertEqual: (ws textLines size) to: 0 message: 'WS-C1a: textLines starts empty'.
    t assertEqual: (ws cursorX) to: 0 message: 'WS-C1b: cursorX starts at 0'.
    t assertEqual: (ws cursorY) to: 0 message: 'WS-C1c: cursorY starts at 0'.
    t assertEqual: (ws scrollOffset) to: 0 message: 'WS-C1d: scrollOffset starts at 0'.

    "WS-C2: Workspace is a subclass of View"
    ws2 := Workspace new.
    ws2 invalidate.
    t assertEqual: (ws2 needsRedraw) to: true message: 'WS-C2a: has needsRedraw (View method)'.

    "WS-C3: Workspace responds to parentWindow:/display: setters"
    ws := Workspace new.
    ws parentWindow: nil.
    ws display: nil.
    t assert: true message: 'WS-C3: setters work without error'.

    "WS-C4: Workspace responds to handleEvent:"
    ws := Workspace new.
    t assert: true message: 'WS-C4: has handleEvent: method'
  ]


"=== WORKSPACE ESCAPE TEST ==="
WSEscapeTests subclass: Object

  classMethod: run: t [
    | ws |
    '--- Workspace Escape Tests ---' println.

    "WS-ESC1: Escape with nil display does not crash"
    ws := Workspace new.
    ws display: nil.
    ws handleEvent: (EvtH keyEvent: #escape).
    t assert: true message: 'WS-ESC1: escape with nil display does not crash'
  ]


"=== TRANSCRIPT CONSTRUCTION TESTS ==="
TRConstructionTests subclass: Object

  classMethod: run: t [
    | tr |
    '--- Transcript Construction Tests ---' println.

    "TR-C1: Transcript new creates instance with correct defaults"
    tr := Transcript new.
    t assertEqual: (tr lines size) to: 0 message: 'TR-C1a: lines starts empty'.
    t assertEqual: (tr maxLines) to: 1000 message: 'TR-C1b: maxLines = 1000'.
    t assertEqual: (tr scrollOffset) to: 0 message: 'TR-C1c: scrollOffset starts at 0'.

    "TR-C2: Transcript is a subclass of View"
    tr := Transcript new.
    tr invalidate.
    t assertEqual: (tr needsRedraw) to: true message: 'TR-C2a: has needsRedraw (View method)'
  ]


"=== TRANSCRIPT SINGLETON TESTS ==="
TRSingletonTests subclass: Object

  classMethod: run: t [
    | tr1 tr2 |
    '--- Transcript Singleton Tests ---' println.

    "TR-S1: Transcript current returns singleton"
    tr1 := Transcript current.
    tr2 := Transcript current.
    t assert: (tr1 == tr2) message: 'TR-S1: Transcript current returns same object'
  ]


"=== TRANSCRIPT APPEND TESTS (0-based indexing) ==="
TRAppendTests subclass: Object

  classMethod: run: t [
    | tr tr2 tr3 i |
    '--- Transcript Append Tests ---' println.

    "TR-A1: appendLine: adds to lines array"
    tr := Transcript new.
    tr appendLine: 'hello'.
    t assertEqual: (tr lines size) to: 1 message: 'TR-A1a: lines size = 1'.
    t assertEqual: (tr lines at: 0) to: 'hello' message: 'TR-A1b: lines at: 0 = hello'.

    "TR-A2: Multiple appends maintain order (newest at bottom)"
    tr appendLine: 'world'.
    t assertEqual: (tr lines size) to: 2 message: 'TR-A2a: lines size = 2'.
    t assertEqual: (tr lines at: 0) to: 'hello' message: 'TR-A2b: first line is hello'.
    t assertEqual: (tr lines at: 1) to: 'world' message: 'TR-A2c: second line is world (newest at bottom)'.

    "TR-A3: appendLine: invalidates"
    tr2 := Transcript new.
    tr2 appendLine: 'trigger'.
    t assertEqual: (tr2 needsRedraw) to: true message: 'TR-A3: appendLine: invalidates'.

    "TR-A4: Many appends preserve order"
    tr3 := Transcript new.
    i := 1.
    [i <= 5] whileTrue: [
      tr3 appendLine: i printString.
      i := i + 1
    ].
    t assertEqual: (tr3 lines at: 0) to: '1' message: 'TR-A4a: first append is 1'.
    t assertEqual: (tr3 lines at: 4) to: '5' message: 'TR-A4b: fifth append is 5 (newest at bottom)'.

    "TR-A5: appendLine: auto-scrolls"
    tr3 := Transcript new.
    tr3 appendLine: 'first'.
    tr3 appendLine: 'second'.
    tr3 appendLine: 'third'.
    t assert: (tr3 scrollOffset >= 0) message: 'TR-A5a: scrollOffset >= 0 after appends'.
    t assertEqual: (tr3 scrollOffset) to: 2 message: 'TR-A5b: scrollOffset = lines size - 1'
  ]


"=== TRANSCRIPT EVENT HANDLING TESTS ==="
TREventTests subclass: Object

  classMethod: run: t [
    | tr tr2 tr3 linesBefore |
    '--- Transcript Event Handling Tests ---' println.

    "TR-EV1: Read-only — rune event does NOT modify lines"
    tr := Transcript new.
    tr appendLine: 'existing'.
    linesBefore := tr lines size.
    tr handleEvent: (EvtH runeEvent: 88).
    t assertEqual: (tr lines size) to: linesBefore message: 'TR-EV1: printable char does not modify lines'.

    "TR-EV2: Up/down events change scrollOffset"
    tr2 := Transcript new.
    tr2 appendLine: 'line1'.
    tr2 appendLine: 'line2'.
    tr2 appendLine: 'line3'.
    "scrollOffset after 3 appends = 2"
    tr2 handleEvent: (EvtH keyEvent: #up).
    t assertEqual: (tr2 scrollOffset) to: 1 message: 'TR-EV2a: scrollOffset decrements on up'.
    tr2 handleEvent: (EvtH keyEvent: #down).
    t assertEqual: (tr2 scrollOffset) to: 2 message: 'TR-EV2b: scrollOffset increments on down'.

    "TR-EV3: scrollOffset does not go below 0"
    tr3 := Transcript new.
    tr3 handleEvent: (EvtH keyEvent: #up).
    tr3 handleEvent: (EvtH keyEvent: #up).
    tr3 handleEvent: (EvtH keyEvent: #up).
    t assertEqual: (tr3 scrollOffset) to: 0 message: 'TR-EV3: scrollOffset clamps at 0'.

    "TR-EV4: scrollOffset clamps on down"
    tr3 := Transcript new.
    tr3 appendLine: 'only'.
    tr3 handleEvent: (EvtH keyEvent: #down).
    tr3 handleEvent: (EvtH keyEvent: #down).
    tr3 handleEvent: (EvtH keyEvent: #down).
    t assert: (tr3 scrollOffset <= ((tr3 lines size - 1) max: 0)) message: 'TR-EV4: down scroll clamps at lines size - 1'.

    "TR-EV5: Escape with nil display does not crash"
    tr := Transcript new.
    tr display: nil.
    tr handleEvent: (EvtH keyEvent: #escape).
    t assert: true message: 'TR-EV5: escape with nil display does not crash'.

    "TR-EV6: Up/down on empty transcript"
    tr := Transcript new.
    tr handleEvent: (EvtH keyEvent: #up).
    t assertEqual: (tr scrollOffset) to: 0 message: 'TR-EV6a: up on empty stays 0'.
    tr handleEvent: (EvtH keyEvent: #down).
    t assertEqual: (tr scrollOffset) to: 0 message: 'TR-EV6b: down on empty stays 0'
  ]


"=== TRANSCRIPT TRIMMING TEST ==="
TRTrimmingTests subclass: Object

  classMethod: run: t [
    | tr i |
    '--- Transcript Trimming Tests ---' println.

    "TR-TRIM1: After exceeding maxLines, oldest lines are trimmed"
    tr := Transcript new.
    "Append more than maxLines (1000) lines"
    i := 1.
    [i <= 1003] whileTrue: [
      tr appendLine: i printString.
      i := i + 1
    ].
    t assert: (tr lines size <= 1000) message: 'TR-TRIM1a: lines trimmed to <= maxLines'.
    t assertEqual: (tr lines size) to: 1000 message: 'TR-TRIM1b: lines size = maxLines after trim'.
    "Newest line should be at the end (0-based)"
    t assertEqual: (tr lines at: 999) to: '1003' message: 'TR-TRIM1c: newest line is last (at: 999)'
  ]


"=== TRANSCRIPT show: CLASS METHOD TEST ==="
TRShowTests subclass: Object

  classMethod: run: t [
    | tr |
    '--- Transcript show: Tests ---' println.

    "TR-SHOW1: Transcript show: appends to the singleton"
    tr := Transcript current.
    Transcript show: 'test message'.
    t assert: (tr lines size > 0) message: 'TR-SHOW1: show: appends to singleton lines'
  ]


"=== WORKSPACE RENDERING TESTS (empty only) ==="
WSRenderTests subclass: Object

  classMethod: run: t [
    | ws buf cell |
    '--- Workspace Rendering Tests ---' println.

    "WR1: Empty workspace renders cursor (reverse-video space) at 0,0"
    ws := Workspace new.
    buf := CellBuffer width: 20 height: 10.
    ws displayOn: buf.
    cell := buf cellAt: 0 y: 0.
    t assert: (cell notNil) message: 'WR1a: cell at 0,0 is non-nil'.
    t assertEqual: (cell at: #char) to: 32 message: 'WR1b: empty cursor is space (32)'.
    t assertEqual: (cell at: #attrs) to: #reverse message: 'WR1c: cursor is reverse-video'
  ]


"=== TRANSCRIPT RENDERING TESTS ==="
TRRenderTests subclass: Object

  classMethod: run: t [
    | tr buf cell |
    '--- Transcript Rendering Tests ---' println.

    "TRR1: Transcript renders lines into buffer"
    tr := Transcript new.
    tr appendLine: 'Hello'.
    tr appendLine: 'World'.
    buf := CellBuffer width: 20 height: 10.
    tr displayOn: buf.
    cell := buf cellAt: 0 y: 0.
    t assert: (cell notNil) message: 'TRR1: transcript renders into buffer'
  ]


"=== CONVENTION COMPLIANCE TESTS ==="
ConvTests subclass: Object

  classMethod: run: t [
    | tr |
    '--- Convention Compliance Tests ---' println.

    "CV1: Workspace textLines starts as empty array"
    t assertEqual: (Workspace new textLines size) to: 0 message: 'CV1: textLines starts as empty array'.

    "CV2: Transcript lines starts as empty array"
    tr := Transcript new.
    t assertEqual: (tr lines size) to: 0 message: 'CV2: lines starts as empty array'.

    "CV3: Transcript grows via append (copyWith: pattern)"
    tr appendLine: 'test'.
    t assertEqual: (tr lines size) to: 1 message: 'CV3: lines grows via append'
  ]


"=== WORKSPACE EDITING TESTS (will crash due to String copyFrom:to: bug) ==="
WSEditingTests subclass: Object

  classMethod: run: t [
    | ws |
    '--- Workspace Text Editing Tests ---' println.

    "WS-E0: Enter on empty workspace creates lines (no String slicing needed)"
    ws := Workspace new.
    ws handleEvent: (EvtH keyEvent: #enter).
    t assert: (ws textLines size > 0) message: 'WS-E0a: enter on empty creates lines'.
    t assertEqual: (ws cursorY) to: 1 message: 'WS-E0b: cursorY = 1 after enter on empty'.

    "WS-E0c: Backspace on empty workspace is no-op"
    ws := Workspace new.
    ws handleEvent: (EvtH keyEvent: #backspace).
    t assertEqual: (ws textLines size) to: 0 message: 'WS-E0c: backspace on empty is no-op'.

    '' println.
    '=== Enter/Backspace results ===' println.
    t report.
    '' println.

    "WS-E1: Inserting a printable char (WILL CRASH - String copyFrom:to: missing)"
    'Attempting rune insert (expected crash on String copyFrom:to:)...' println.
    ws := Workspace new.
    ws handleEvent: (EvtH runeEvent: 65).
    t assertEqual: (ws textLines size) to: 1 message: 'WS-E1a: textLines has 1 line'.
    t assertEqual: (ws textLines at: 0) to: 'A' message: 'WS-E1b: first line is A'.
    t assertEqual: (ws cursorX) to: 1 message: 'WS-E1c: cursorX = 1'
  ]


"=== MAIN RUNNER ==="
Phase5SpecTests subclass: Object
  classMethod: run [
    | t |
    t := T5S new.

    "Run stable tests first (no string slicing)"
    WSConstructionTests run: t.
    '' println.
    WSEscapeTests run: t.
    '' println.
    TRConstructionTests run: t.
    '' println.
    TRSingletonTests run: t.
    '' println.
    TRAppendTests run: t.
    '' println.
    TREventTests run: t.
    '' println.
    TRTrimmingTests run: t.
    '' println.
    TRShowTests run: t.
    '' println.
    ConvTests run: t.
    '' println.
    WSRenderTests run: t.

    '' println.
    '=== Stable test results ===' println.
    t report.
    '' println.

    "Workspace editing tests — will crash due to String copyFrom:to: bug"
    'Attempting Workspace editing tests (may crash on String copyFrom:to:)...' println.
    WSEditingTests run: t.

    '' println.
    'Attempting Transcript rendering tests (may crash on CellBuffer charCode bug)...' println.
    TRRenderTests run: t.

    '' println.
    '=== Final results ===' println.
    t report.
    ^ t failed
  ]

Phase5SpecTests run

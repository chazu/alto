namespace: 'Alto'
import: 'Go'

TMS subclass: Object
  instanceVars: passed failed failures

  method: init [
      passed := 0.
      failed := 0.
      failures := Array new: 0
  ]

  method: assert: condition message: msg [
      condition ifTrue: [passed := passed + 1]
        ifFalse: [
        failed := failed + 1.
        failures := failures copyWith: msg.
        ('FAIL: ' , msg) println
      ]
  ]

  method: assertEqual: actual to: expected message: msg [
      actual = expected ifTrue: [passed := passed + 1]
        ifFalse: [
        failed := failed + 1.
        failures := failures copyWith: msg.
        ('FAIL: ' , msg , ' (got: ' , actual printString , ' expected: ' , expected printString , ')') println
      ]
  ]

  method: report [
      '=== Mouse Support Test Results ===' println.
      ('Passed: ' , passed printString) println.
      ('Failed: ' , failed printString) println.
      failed > 0 ifTrue: [
        'Failures:' println.
        failures do: [:f | ('  - ' , f) println]
      ].
      failed = 0 ifTrue: ['ALL TESTS PASSED' println]
        ifFalse: ['SOME TESTS FAILED' println]
  ]

  method: failed [
      ^failed
  ]

  classMethod: new [
      | r |
      r := super new.
      r init.
      ^r
  ]

MockMouseEvent subclass: Object
  instanceVars: posArray buttonsVal

  method: setPos: aPos buttons: aBtn [
      posArray := aPos.
      buttonsVal := aBtn
  ]

  method: position [
      ^posArray
  ]

  method: buttons [
      ^buttonsVal
  ]

  method: isKindOf: aClass [
      aClass = Go::V2::EventMouse ifTrue: [^true].
      ^false
  ]

  classMethod: mx: anMx my: anMy buttons: aBtn [
      | inst pos |
      inst := super new.
      pos := Array new: 2.
      pos at: 0 put: anMx.
      pos at: 1 put: anMy.
      inst setPos: pos buttons: aBtn.
      ^inst
  ]

MockKeyEvent subclass: Object
  instanceVars: keyVal runeVal

  method: setKey: aKey rune: aRune [
      keyVal := aKey.
      runeVal := aRune
  ]

  method: key [
      ^keyVal
  ]

  method: rune [
      ^runeVal
  ]

  method: isKindOf: aClass [
      aClass = Go::V2::EventKey ifTrue: [^true].
      ^false
  ]

  classMethod: key: aKey rune: aRune [
      | inst |
      inst := super new.
      inst setKey: aKey rune: aRune.
      ^inst
  ]

MockCtrl subclass: Object
  instanceVars: events mouseEvents

  method: initCtrl [
      events := Array new: 0.
      mouseEvents := Array new: 0
  ]

  method: handleEvent: evt [
      events := events copyWith: evt
  ]

  method: handleMouseLocalX: x y: y buttons: btn [
      | info |
      info := Array new: 3.
      info at: 0 put: x.
      info at: 1 put: y.
      info at: 2 put: btn.
      mouseEvents := mouseEvents copyWith: info
  ]

  method: events [
      ^events
  ]

  method: mouseEvents [
      ^mouseEvents
  ]

  method: eventCount [
      ^events size
  ]

  method: mouseEventCount [
      ^mouseEvents size
  ]

  classMethod: new [
      | inst |
      inst := super new.
      inst initCtrl.
      ^inst
  ]

MockDisplay subclass: Object
  instanceVars: windowsList removedWindows broughtToFront

  method: initDisplay [
      windowsList := Array new: 0.
      removedWindows := Array new: 0.
      broughtToFront := Array new: 0
  ]

  method: addWindow: w [
      windowsList := windowsList copyWith: w
  ]

  method: removeWindow: w [
      removedWindows := removedWindows copyWith: w.
      windowsList := windowsList reject: [:each | each = w]
  ]

  method: bringToFront: w [
      broughtToFront := broughtToFront copyWith: w.
      windowsList := windowsList reject: [:each | each = w].
      windowsList := windowsList copyWith: w
  ]

  method: windows [
      ^windowsList
  ]

  method: removedWindows [
      ^removedWindows
  ]

  method: broughtToFront [
      ^broughtToFront
  ]

  classMethod: new [
      | inst |
      inst := super new.
      inst initDisplay.
      ^inst
  ]

DisplayMouseTests subclass: Object

  classMethod: run: t [
      | disp rect1 rect2 win1 win2 evt mc1 mc2 disp2 rect3 rect4 win3 win4 evt2 disp3 rect5 win5 evt3 evt4 |
      '--- Display Mouse Dispatch Tests ---' println.
      disp := MockDisplay new.
      rect1 := Rectangle x: 0 y: 0 width: 20 height: 10.
      rect2 := Rectangle x: 10 y: 5 width: 20 height: 10.
      mc1 := MockCtrl new.
      mc2 := MockCtrl new.
      win1 := Window title: 'W1' content: nil controller: mc1 frame: rect1.
      win2 := Window title: 'W2' content: nil controller: mc2 frame: rect2.
      disp addWindow: win1.
      disp addWindow: win2.
      t assert: (rect2 containsPointX: 15 y: 8)
        message: 'DM1a: point (15,8) is inside rect2'.
      t assert: (rect1 containsPointX: 5 y: 3)
        message: 'DM1b: point (5,3) is inside rect1'.
      t assert: (rect1 containsPointX: 15 y: 8)
        message: 'DM1c: point (15,8) is inside rect1 (overlap)'.
      t assert: (rect2 containsPointX: 15 y: 8)
        message: 'DM2: frontmost window found first in reverse z-order'.
      t assert: (rect1 containsPointX: 5 y: 3) message: 'DM3a: (5,3) inside win1'.
      t assert: (rect2 containsPointX: 5 y: 3) not
        message: 'DM3b: (5,3) NOT inside win2'.
      disp bringToFront: win1.
      t assertEqual: disp broughtToFront size
        to: 1
        message: 'DM3c: bringToFront called once'.
      t assertEqual: (disp broughtToFront at: 0)
        to: win1
        message: 'DM3d: bringToFront called with win1'.
      t assertEqual: (disp windows at: disp windows size - 1)
        to: win1
        message: 'DM3e: win1 now frontmost after bringToFront'.
      disp2 := MockDisplay new.
      rect3 := Rectangle x: 0 y: 0 width: 30 height: 15.
      mc1 := MockCtrl new.
      win3 := Window title: 'Fwd' content: nil controller: mc1 frame: rect3.
      win3 display: disp2.
      disp2 addWindow: win3.
      evt := MockMouseEvent mx: 5 my: 5 buttons: 1.
      win3 handleEvent: evt.
      t assertEqual: mc1 mouseEventCount
        to: 1
        message: 'DM4: mouse event forwarded to target window controller'.
      t assertEqual: ((mc1 mouseEvents at: 0) at: 0)
        to: 4
        message: 'DM4b: content-local x = screen x - frame x - border'.
      t assertEqual: ((mc1 mouseEvents at: 0) at: 1)
        to: 4
        message: 'DM4c: content-local y = screen y - frame y - title'.
      disp3 := MockDisplay new.
      rect5 := Rectangle x: 10 y: 10 width: 5 height: 5.
      win5 := Window title: 'Small' content: nil controller: nil frame: rect5.
      disp3 addWindow: win5.
      t assert: (rect5 containsPointX: 0 y: 0) not
        message: 'DM5: click outside all windows finds no target'.
      disp2 := MockDisplay new.
      rect3 := Rectangle x: 0 y: 0 width: 20 height: 10.
      rect4 := Rectangle x: 5 y: 5 width: 20 height: 10.
      win3 := Window title: 'Back' content: nil controller: nil frame: rect3.
      win4 := Window title: 'Front' content: nil controller: nil frame: rect4.
      disp2 addWindow: win3.
      disp2 addWindow: win4.
      t assert: (rect4 containsPointX: 10 y: 8)
        message: 'DM6a: (10,8) inside win4'.
      t assertEqual: disp2 broughtToFront size
        to: 0
        message: 'DM6b: bringToFront not called for frontmost window'.
      rect3 := Rectangle x: 20 y: 10 width: 15 height: 8.
      t assert: (rect3 containsPointX: 25 y: 14)
        message: 'DM7a: point inside offset window'.
      t assert: (rect3 containsPointX: 19 y: 14) not
        message: 'DM7b: point left of offset window'.
      t assert: (rect3 containsPointX: 25 y: 9) not
        message: 'DM7c: point above offset window'.
      t assert: (rect3 containsPointX: 35 y: 14) not
        message: 'DM7d: point right of offset window (x >= x+width)'.
      t assert: (rect3 containsPointX: 25 y: 18) not
        message: 'DM7e: point below offset window (y >= y+height)'.
      disp3 := MockDisplay new.
      rect5 := Rectangle x: 10 y: 5 width: 20 height: 10.
      mc1 := MockCtrl new.
      win5 := Window title: 'OffsetWin' content: nil controller: mc1 frame: rect5.
      win5 display: disp3.
      disp3 addWindow: win5.
      evt := MockMouseEvent mx: 15 my: 8 buttons: 1.
      win5 handleEvent: evt.
      t assertEqual: mc1 mouseEventCount
        to: 1
        message: 'DM8: mouse event forwarded to offset window controller'.
      t assertEqual: ((mc1 mouseEvents at: 0) at: 0)
        to: 4
        message: 'DM8b: content-local x = 15 - 10 - 1 = 4'.
      t assertEqual: ((mc1 mouseEvents at: 0) at: 1)
        to: 2
        message: 'DM8c: content-local y = 8 - 5 - 1 = 2'
  ]

WindowMouseTests subclass: Object

  classMethod: run: t [
      | rect win mc evt disp win2 mc2 evt2 win3 mc3 evt3 win4 mc4 evt4 win5 disp2 evt5 |
      '--- Window Mouse Event Tests ---' println.
      rect := Rectangle x: 0 y: 0 width: 30 height: 15.
      mc := MockCtrl new.
      disp := MockDisplay new.
      win := Window title: 'CloseMe' content: nil controller: mc frame: rect.
      win display: disp.
      disp addWindow: win.
      evt := MockMouseEvent mx: 26 my: 0 buttons: 1.
      win handleEvent: evt.
      t assertEqual: mc eventCount
        to: 0
        message: 'WM1a: close box click not dispatched to controller'.
      t assertEqual: disp removedWindows size
        to: 1
        message: 'WM1b: close box click removes window from display'.
      t assertEqual: (disp removedWindows at: 0)
        to: win
        message: 'WM1c: correct window removed'.
      rect := Rectangle x: 0 y: 0 width: 20 height: 10.
      mc2 := MockCtrl new.
      disp2 := MockDisplay new.
      win2 := Window title: 'Edge' content: nil controller: mc2 frame: rect.
      win2 display: disp2.
      disp2 addWindow: win2.
      evt2 := MockMouseEvent mx: 16 my: 0 buttons: 1.
      win2 handleEvent: evt2.
      t assertEqual: disp2 removedWindows size
        to: 1
        message: 'WM2: close box at exact boundary triggers close'.
      rect := Rectangle x: 0 y: 0 width: 30 height: 15.
      mc3 := MockCtrl new.
      win3 := Window title: 'TitleBar' content: nil controller: mc3 frame: rect.
      evt3 := MockMouseEvent mx: 5 my: 0 buttons: 1.
      win3 handleEvent: evt3.
      t assertEqual: mc3 eventCount
        to: 0
        message: 'WM3: title bar click (not close box) does not delegate to controller'.
      rect := Rectangle x: 0 y: 0 width: 30 height: 15.
      mc4 := MockCtrl new.
      win4 := Window title: 'Body' content: nil controller: mc4 frame: rect.
      evt4 := MockMouseEvent mx: 10 my: 5 buttons: 1.
      win4 handleEvent: evt4.
      t assertEqual: mc4 mouseEventCount
        to: 1
        message: 'WM4a: body click delegates to contentController via handleMouseLocalX:y:buttons:'.
      t assertEqual: ((mc4 mouseEvents at: 0) at: 0)
        to: 9
        message: 'WM4b: content-local x = 10 - 0 - 1 = 9'.
      t assertEqual: ((mc4 mouseEvents at: 0) at: 1)
        to: 4
        message: 'WM4c: content-local y = 5 - 0 - 1 = 4'.
      rect := Rectangle x: 0 y: 0 width: 30 height: 15.
      win5 := Window title: 'NilCtrl' content: nil controller: nil frame: rect.
      evt5 := MockMouseEvent mx: 10 my: 5 buttons: 1.
      win5 handleEvent: evt5.
      t assert: true
        message: 'WM5: body click with nil controller does not crash'.
      rect := Rectangle x: 0 y: 0 width: 20 height: 10.
      disp := MockDisplay new.
      win := Window title: 'CloseDirect' content: nil controller: nil frame: rect.
      win display: disp.
      disp addWindow: win.
      win close.
      t assertEqual: disp removedWindows size
        to: 1
        message: 'WM6a: close removes from display'.
      t assertEqual: disp windows size
        to: 0
        message: 'WM6b: window no longer in display windows'.
      win := Window title: 'NoDisp' content: nil controller: nil frame: rect.
      win close.
      t assert: true message: 'WM7: close with nil display does not crash'.
      rect := Rectangle x: 0 y: 0 width: 20 height: 10.
      disp := MockDisplay new.
      win := Window title: 'Right' content: nil controller: nil frame: rect.
      win display: disp.
      disp addWindow: win.
      evt := MockMouseEvent mx: 19 my: 0 buttons: 1.
      win handleEvent: evt.
      t assertEqual: disp removedWindows size
        to: 1
        message: 'WM8: click at rightmost x still triggers close'.
      rect := Rectangle x: 0 y: 0 width: 30 height: 15.
      mc := MockCtrl new.
      win := Window title: 'Keys' content: nil controller: mc frame: rect.
      evt := MockKeyEvent key: 65 rune: 65.
      win handleEvent: evt.
      t assertEqual: mc eventCount
        to: 1
        message: 'WM9: key event delegates to controller'.
      rect := Rectangle x: 10 y: 5 width: 30 height: 15.
      disp := MockDisplay new.
      win := Window title: 'Offset' content: nil controller: nil frame: rect.
      win display: disp.
      disp addWindow: win.
      evt := MockMouseEvent mx: 36 my: 5 buttons: 1.
      win handleEvent: evt.
      t assertEqual: disp removedWindows size
        to: 1
        message: 'WM10: close box works with screen coords on offset window (screen 36,5 -> local 26,0)'.
      rect := Rectangle x: 10 y: 5 width: 30 height: 15.
      mc := MockCtrl new.
      win := Window title: 'OffsetBody' content: nil controller: mc frame: rect.
      evt := MockMouseEvent mx: 15 my: 7 buttons: 1.
      win handleEvent: evt.
      t assertEqual: mc mouseEventCount
        to: 1
        message: 'WM11: body click on offset window delegates to controller (screen 15,7 -> local 5,2 -> content 4,1)'
  ]

ListViewMouseTests subclass: Object

  classMethod: run: t [
      | lv holder lv2 lv3 lv4 lv5 lv6 |
      '--- ListView Mouse Event Tests ---' println.
      lv := ListView items: #('Alpha' 'Beta' 'Gamma' 'Delta') onSelect: nil.
      t assertEqual: lv selectedIndex
        to: 0
        message: 'LM1a: selectedIndex starts at 0'.
      lv handleMouseLocalX: 5 y: 2 buttons: 1.
      t assertEqual: lv selectedIndex
        to: 2
        message: 'LM1b: left click sets selectedIndex to scrollOffset + y'.
      t assertEqual: lv selectedItem
        to: 'Gamma'
        message: 'LM1c: selectedItem is Gamma after click'.
      holder := Array new: 1.
      lv2 := ListView items: #('Alpha' 'Beta' 'Gamma')
        onSelect: [:item | holder at: 0 put: item].
      lv2 handleMouseLocalX: 0 y: 1 buttons: 1.
      t assertEqual: lv2 selectedIndex
        to: 1
        message: 'LM2a: selectedIndex set to 1'.
      t assertEqual: (holder at: 0)
        to: 'Beta'
        message: 'LM2b: onSelectBlock called with selected item'.
      lv3 := ListView items: #('One' 'Two') onSelect: nil.
      lv3 handleMouseLocalX: 0 y: 5 buttons: 1.
      t assertEqual: lv3 selectedIndex
        to: 0
        message: 'LM3: out-of-bounds click does not change selectedIndex'.
      lv4 := ListView items: #('Alpha' 'Beta' 'Gamma') onSelect: nil.
      lv4 handleMouseLocalX: 0 y: 2 buttons: 2.
      t assertEqual: lv4 selectedIndex
        to: 0
        message: 'LM4: right click (buttons=2) does not change selectedIndex'.
      lv5 := ListView items: #('First' 'Second' 'Third') onSelect: nil.
      lv5 handleMouseLocalX: 0 y: 0 buttons: 1.
      t assertEqual: lv5 selectedIndex
        to: 0
        message: 'LM5: click at y=0 selects first item'.
      t assertEqual: lv5 selectedItem
        to: 'First'
        message: 'LM5b: selectedItem is First'.
      lv6 := ListView items: #() onSelect: nil.
      lv6 handleMouseLocalX: 0 y: 0 buttons: 1.
      t assertEqual: lv6 selectedIndex
        to: 0
        message: 'LM6: click on empty list does not crash'.
      lv := ListView items: #('A' 'B' 'C') onSelect: nil.
      lv handleMouseLocalX: 0 y: 2 buttons: 1.
      t assertEqual: lv selectedIndex
        to: 2
        message: 'LM7: click at last valid index selects it'.
      t assertEqual: lv selectedItem to: 'C' message: 'LM7b: selectedItem is C'.
      lv := ListView items: #('X' 'Y' 'Z') onSelect: nil.
      lv handleMouseLocalX: 0 y: 0 buttons: 0.
      t assertEqual: lv selectedIndex
        to: 0
        message: 'LM8: zero-button mouse event handled without crash'.
      lv := ListView items: #('Alpha' 'Beta' 'Gamma') onSelect: nil.
      lv handleMouseLocalX: 0 y: 1 buttons: 2.
      t assertEqual: lv selectedIndex
        to: 0
        message: 'LM9: middle click (buttons=2) does not change selection'.
      lv := ListView items: #('Alpha' 'Beta' 'Gamma') onSelect: nil.
      lv handleMouseLocalX: 0 y: 2 buttons: 0.
      t assertEqual: lv selectedIndex
        to: 0
        message: 'LM10: ButtonNone does not change selection'
  ]

SystemBrowserMouseTests subclass: Object

  classMethod: run: t [
      | sb paneWidth sb2 sb3 sb4 sb5 sb6 sb7 sb8 |
      '--- SystemBrowser Mouse Event Tests ---' println.
      paneWidth := 26.
      sb := SystemBrowser new.
      sb handleEvent: (MockKeyEvent key: 9 rune: 0).
      t assertEqual: sb focusedPane
        to: 1
        message: 'SM1a: focusedPane starts at 1 after Tab'.
      sb handleMouseLocalX: 5 y: 1 buttons: 1.
      t assertEqual: sb focusedPane
        to: 0
        message: 'SM1b: click in category pane sets focusedPane to 0'.
      sb2 := SystemBrowser new.
      t assertEqual: sb2 selectedCategory
        to: 'Kernel'
        message: 'SM2a: starts at Kernel'.
      sb2 handleMouseLocalX: 5 y: 1 buttons: 1.
      t assertEqual: sb2 selectedCategory
        to: 'Display'
        message: 'SM2b: click at y=1 selects Display'.
      sb3 := SystemBrowser new.
      sb3 handleEvent: (MockKeyEvent key: 259 rune: 0).
      t assertEqual: sb3 selectedCategory
        to: 'Display'
        message: 'SM3a: navigated to Display'.
      sb3 handleMouseLocalX: 5 y: 0 buttons: 1.
      t assertEqual: sb3 selectedCategory
        to: 'Kernel'
        message: 'SM3b: click at y=0 selects Kernel'.
      sb4 := SystemBrowser new.
      t assertEqual: sb4 focusedPane
        to: 0
        message: 'SM4a: focusedPane starts at 0'.
      sb4 handleMouseLocalX: paneWidth + 2 y: 0 buttons: 1.
      t assertEqual: sb4 focusedPane
        to: 1
        message: 'SM4b: click in class pane sets focusedPane to 1'.
      sb5 := SystemBrowser new.
      t assertEqual: sb5 selectedCategory
        to: 'Kernel'
        message: 'SM5a: category is Kernel'.
      sb5 handleMouseLocalX: paneWidth + 2 y: 0 buttons: 1.
      t assertEqual: sb5 selectedClass
        to: 'Rectangle'
        message: 'SM5b: click at y=0 in class pane selects Rectangle'.
      sb6 := SystemBrowser new.
      sb6 handleMouseLocalX: paneWidth + 2 y: 0 buttons: 1.
      t assertEqual: sb6 selectedClass
        to: 'Rectangle'
        message: 'SM6a: Rectangle selected'.
      sb6 handleMouseLocalX: paneWidth * 2 + 2 y: 0 buttons: 1.
      t assertEqual: sb6 focusedPane
        to: 2
        message: 'SM6b: click in method pane sets focusedPane to 2'.
      sb7 := SystemBrowser new.
      sb7 handleMouseLocalX: paneWidth + 2 y: 0 buttons: 1.
      sb7 handleMouseLocalX: paneWidth * 2 + 2 y: 0 buttons: 1.
      t assertEqual: sb7 selectedMethod
        to: 'x:y:width:height:'
        message: 'SM7: click at y=0 in method pane selects first method'.
      sb8 := SystemBrowser new.
      sb8 handleMouseLocalX: 5 y: 2 buttons: 2.
      t assertEqual: sb8 selectedCategory
        to: 'Kernel'
        message: 'SM8a: right click does not change category'.
      t assertEqual: sb8 focusedPane
        to: 0
        message: 'SM8b: right click does not change focusedPane'.
      sb := SystemBrowser new.
      sb handleMouseLocalX: 5 y: 10 buttons: 1.
      t assertEqual: sb selectedCategory
        to: 'Kernel'
        message: 'SM9: out-of-bounds category click does not change selection'.
      sb := SystemBrowser new.
      sb handleMouseLocalX: paneWidth + 2 y: 5 buttons: 1.
      t assertEqual: sb selectedClass
        to: nil
        message: 'SM10: out-of-bounds class click does not set selectedClass'.
      sb := SystemBrowser new.
      sb handleMouseLocalX: paneWidth + 2 y: 0 buttons: 1.
      t assertEqual: sb selectedClass
        to: 'Rectangle'
        message: 'SM11a: class selected'.
      sb handleMouseLocalX: 5 y: 2 buttons: 1.
      t assertEqual: sb selectedCategory
        to: 'MVC'
        message: 'SM11b: category changed to MVC'.
      t assertEqual: sb selectedClass
        to: nil
        message: 'SM11c: selectedClass reset after category change'.
      sb := SystemBrowser new.
      sb handleMouseLocalX: paneWidth + 2 y: 0 buttons: 1.
      t assertEqual: sb focusedPane
        to: 1
        message: 'SM12: focusedPane updated after class pane click'.
      sb := SystemBrowser new.
      sb handleMouseLocalX: paneWidth * 3 + 2 y: 0 buttons: 1.
      t assertEqual: sb focusedPane
        to: 3
        message: 'SM13: click beyond 3 panes sets focusedPane to 3'.
      sb := SystemBrowser new.
      sb handleMouseLocalX: paneWidth y: 0 buttons: 1.
      t assertEqual: sb focusedPane
        to: 1
        message: 'SM14: click at exact paneWidth boundary goes to class pane'.
      sb := SystemBrowser new.
      sb handleMouseLocalX: paneWidth + 2 y: 0 buttons: 1.
      t assertEqual: sb selectedClass
        to: 'Rectangle'
        message: 'SM15a: Rectangle selected'.
      t assertEqual: sb selectedMethod
        to: nil
        message: 'SM15b: selectedMethod nil after class select'.
      sb := SystemBrowser new.
      sb handleMouseLocalX: 5 y: 4 buttons: 1.
      t assertEqual: sb selectedCategory
        to: 'Tools'
        message: 'SM16: click at y=4 selects Tools'
  ]

MouseConventionTests subclass: Object

  classMethod: run: t [
      | mEvt kEvt |
      '--- Convention Tests ---' println.
      mEvt := MockMouseEvent mx: 0 my: 0 buttons: 1.
      t assert: (mEvt isKindOf: Go::V2::EventMouse)
        message: 'MC1: MockMouseEvent isKindOf: Go::V2::EventMouse'.
      t assert: (mEvt isKindOf: Go::V2::EventKey) not
        message: 'MC2: MockMouseEvent not isKindOf: Go::V2::EventKey'.
      kEvt := MockKeyEvent key: 65 rune: 65.
      t assert: (kEvt isKindOf: Go::V2::EventKey)
        message: 'MC3: MockKeyEvent isKindOf: Go::V2::EventKey'.
      t assert: (kEvt isKindOf: Go::V2::EventMouse) not
        message: 'MC4: MockKeyEvent not isKindOf: Go::V2::EventMouse'.
      mEvt := MockMouseEvent mx: 42 my: 17 buttons: 3.
      t assertEqual: (mEvt position at: 0)
        to: 42
        message: 'MC5a: position at: 0 is mx'.
      t assertEqual: (mEvt position at: 1)
        to: 17
        message: 'MC5b: position at: 1 is my'.
      t assertEqual: mEvt buttons
        to: 3
        message: 'MC5c: buttons returns correct value'
  ]

MouseSupportTests subclass: Object

  classMethod: run [
      | t |
      t := TMS new.
      DisplayMouseTests run: t.
      '' println.
      WindowMouseTests run: t.
      '' println.
      ListViewMouseTests run: t.
      '' println.
      SystemBrowserMouseTests run: t.
      '' println.
      MouseConventionTests run: t.
      '' println.
      t report.
      ^t failed
  ]
